# Copy this file to .env and fill in your values

# Your AccuLynx API key — get it from https://my.acculynx.com/apikeys
ACCULYNX_API_KEY=your_acculynx_api_key_here

# Port the relay server listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed origins (your website domain)
# Use * to allow all origins during development only
# Example: https://yourcompany.com,https://www.yourcompany.com
ALLOWED_ORIGINS=https://yourcompany.com
